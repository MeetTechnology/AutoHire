generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum TokenStatus {
  ACTIVE
  EXPIRED
  DISABLED
}

enum ApplicationStatus {
  INIT
  INTRO_VIEWED
  CV_UPLOADED
  CV_ANALYZING
  INFO_REQUIRED
  REANALYZING
  INELIGIBLE
  ELIGIBLE
  MATERIALS_IN_PROGRESS
  SUBMITTED
  CLOSED
}

enum EligibilityResult {
  UNKNOWN
  INSUFFICIENT_INFO
  ELIGIBLE
  INELIGIBLE
}

enum AnalysisJobStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
}

enum AnalysisJobType {
  INITIAL
  REANALYSIS
}

enum MaterialCategory {
  IDENTITY
  EMPLOYMENT
  EDUCATION
  HONOR
  PATENT
  PROJECT
}

model ExpertInvitation {
  id          String      @id @default(cuid())
  expertId    String
  email       String?
  tokenHash   String      @unique
  tokenStatus TokenStatus @default(ACTIVE)
  expiredAt   DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  applications Application[]

  @@index([expertId])
}

model Application {
  id                  String             @id @default(cuid())
  expertId            String
  invitationId        String
  applicationStatus   ApplicationStatus  @default(INIT)
  currentStep         String?
  eligibilityResult   EligibilityResult  @default(UNKNOWN)
  latestAnalysisJobId String?
  submittedAt         DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  invitation           ExpertInvitation           @relation(fields: [invitationId], references: [id])
  resumeFiles          ResumeFile[]
  analysisJobs         ResumeAnalysisJob[]
  analysisResults      ResumeAnalysisResult[]
  supplementalFields   SupplementalFieldSubmission[]
  materials            ApplicationMaterial[]
  events               ApplicationEventLog[]

  @@index([expertId])
  @@index([applicationStatus])
}

model ResumeFile {
  id            String      @id @default(cuid())
  applicationId String
  fileName      String
  objectKey     String
  fileType      String
  fileSize      Int
  versionNo     Int         @default(1)
  uploadedAt    DateTime    @default(now())

  application Application @relation(fields: [applicationId], references: [id])

  @@index([applicationId])
}

model ResumeAnalysisJob {
  id            String            @id @default(cuid())
  applicationId String
  externalJobId String?           @unique
  jobType       AnalysisJobType
  jobStatus     AnalysisJobStatus @default(QUEUED)
  stageText     String?
  errorMessage  String?
  startedAt     DateTime          @default(now())
  finishedAt    DateTime?

  application Application @relation(fields: [applicationId], references: [id])

  @@index([applicationId])
}

model ResumeAnalysisResult {
  id                String            @id @default(cuid())
  applicationId     String
  analysisJobId     String
  analysisRound     Int               @default(1)
  eligibilityResult EligibilityResult @default(UNKNOWN)
  reasonText        String?
  displaySummary    String?
  extractedFields   Json?
  missingFields     Json?
  createdAt         DateTime          @default(now())

  application Application @relation(fields: [applicationId], references: [id])

  @@index([applicationId])
  @@index([analysisJobId])
}

model SupplementalFieldSubmission {
  id            String   @id @default(cuid())
  applicationId String
  analysisJobId String?
  fieldValues   Json
  submittedAt   DateTime @default(now())

  application Application @relation(fields: [applicationId], references: [id])

  @@index([applicationId])
}

model ApplicationMaterial {
  id            String           @id @default(cuid())
  applicationId String
  category      MaterialCategory
  fileName      String
  objectKey     String
  fileType      String
  fileSize      Int
  uploadedAt    DateTime         @default(now())
  isDeleted     Boolean          @default(false)

  application Application @relation(fields: [applicationId], references: [id])

  @@index([applicationId, category])
}

model ApplicationEventLog {
  id            String   @id @default(cuid())
  applicationId String
  eventType     String
  eventPayload  Json?
  createdAt     DateTime @default(now())

  application Application @relation(fields: [applicationId], references: [id])

  @@index([applicationId])
  @@index([eventType])
}
