generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum TokenStatus {
  ACTIVE
  EXPIRED
  DISABLED
}

enum ApplicationStatus {
  INIT
  INTRO_VIEWED
  CV_UPLOADED
  CV_ANALYZING
  INFO_REQUIRED
  REANALYZING
  INELIGIBLE
  ELIGIBLE
  SECONDARY_ANALYZING
  SECONDARY_REVIEW
  SECONDARY_FAILED
  MATERIALS_IN_PROGRESS
  SUBMITTED
  CLOSED
}

enum EligibilityResult {
  UNKNOWN
  INSUFFICIENT_INFO
  ELIGIBLE
  INELIGIBLE
}

enum AnalysisJobStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
}

enum AnalysisJobType {
  INITIAL
  REANALYSIS
}

enum MaterialCategory {
  IDENTITY
  EMPLOYMENT
  EDUCATION
  HONOR
  PATENT
  PROJECT
  PAPER
  BOOK
  CONFERENCE
  PRODUCT
}

enum AccessResult {
  VALID
  INVALID
  EXPIRED
  DISABLED
  SESSION_RESTORE
}

enum AccessTokenStatusSnapshot {
  UNKNOWN
  ACTIVE
  EXPIRED
  DISABLED
}

enum EventStatus {
  SUCCESS
  FAIL
}

enum UploadKind {
  RESUME
  MATERIAL
}

enum UploadFailureStage {
  INTENT
  PUT
  CONFIRM
}

model ExpertInvitation {
  id          String      @id @default(cuid())
  expertId    String
  email       String?
  tokenHash   String      @unique
  tokenStatus TokenStatus @default(ACTIVE)
  expiredAt   DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  applications Application[]
  accessLogs   InviteAccessLog[]

  @@index([expertId])
}

model Application {
  id                          String             @id @default(cuid())
  expertId                    String
  invitationId                String             @unique
  applicationStatus           ApplicationStatus  @default(INIT)
  currentStep                 String?
  eligibilityResult           EligibilityResult  @default(UNKNOWN)
  latestAnalysisJobId         String?
  firstAccessedAt             DateTime?
  lastAccessedAt              DateTime?
  introConfirmedAt            DateTime?
  resumeUploadStartedAt       DateTime?
  resumeUploadedAt            DateTime?
  analysisStartedAt           DateTime?
  analysisCompletedAt         DateTime?
  materialsEnteredAt          DateTime?
  submittedAt                 DateTime?
  screeningPassportFullName   String?
  screeningContactEmail       String?
  screeningPhoneNumber        String?
  productInnovationDescription String?          @db.Text
  createdAt                   DateTime           @default(now())
  updatedAt                   DateTime           @updatedAt

  invitation                  ExpertInvitation              @relation(fields: [invitationId], references: [id])
  resumeFiles                 ResumeFile[]
  analysisJobs                ResumeAnalysisJob[]
  analysisResults             ResumeAnalysisResult[]
  secondaryAnalysisRuns       SecondaryAnalysisRun[]
  secondaryAnalysisFieldValues SecondaryAnalysisFieldValue[]
  supplementalFields          SupplementalFieldSubmission[]
  materials                   ApplicationMaterial[]
  events                      ApplicationEventLog[]
  accessLogs                  InviteAccessLog[]
  fileUploadAttempts          FileUploadAttempt[]

  @@index([expertId])
  @@index([applicationStatus])
  @@index([firstAccessedAt])
  @@index([lastAccessedAt])
  @@index([introConfirmedAt])
  @@index([resumeUploadedAt])
  @@index([analysisCompletedAt])
  @@index([materialsEnteredAt])
  @@index([submittedAt])
}

model ResumeFile {
  id            String      @id @default(cuid())
  applicationId String
  fileName      String
  objectKey     String
  fileType      String
  fileSize      Int
  versionNo     Int         @default(1)
  uploadedAt    DateTime    @default(now())

  application Application @relation(fields: [applicationId], references: [id])
  analysisJobs ResumeAnalysisJob[]

  @@index([applicationId])
  @@unique([applicationId, versionNo])
}

model ResumeAnalysisJob {
  id            String            @id @default(cuid())
  applicationId String
  resumeFileId  String?
  externalJobId String?           @unique
  jobType       AnalysisJobType
  jobStatus     AnalysisJobStatus @default(QUEUED)
  stageText     String?
  errorMessage  String?
  startedAt     DateTime          @default(now())
  finishedAt    DateTime?

  application                  Application                   @relation(fields: [applicationId], references: [id])
  resumeFile                   ResumeFile?                   @relation(fields: [resumeFileId], references: [id])
  analysisResult               ResumeAnalysisResult?
  secondaryAnalysisRuns        SecondaryAnalysisRun[]
  supplementalFieldSubmissions SupplementalFieldSubmission[]

  @@index([applicationId])
  @@index([resumeFileId])
}

model ResumeAnalysisResult {
  id                String            @id @default(cuid())
  applicationId     String
  analysisJobId     String            @unique
  analysisRound     Int               @default(1)
  eligibilityResult EligibilityResult @default(UNKNOWN)
  reasonText        String?
  displaySummary    String?
  extractedFields   Json?
  missingFields     Json?
  createdAt         DateTime          @default(now())

  application Application @relation(fields: [applicationId], references: [id])
  analysisJob ResumeAnalysisJob @relation(fields: [analysisJobId], references: [id])

  @@index([applicationId])
}

model SecondaryAnalysisRun {
  id             String   @id @default(cuid())
  applicationId  String
  analysisJobId  String?
  externalRunId  String
  status         String
  errorMessage   String?
  runSummary     Json?
  rawResults     Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  application Application @relation(fields: [applicationId], references: [id])
  analysisJob ResumeAnalysisJob? @relation(fields: [analysisJobId], references: [id])
  fieldValues SecondaryAnalysisFieldValue[]

  @@unique([applicationId, externalRunId])
  @@index([applicationId])
  @@index([analysisJobId])
}

model SecondaryAnalysisFieldValue {
  id               String   @id @default(cuid())
  applicationId    String
  secondaryRunId   String
  no               Int
  columnName       String?
  label            String
  sourceValue      String?
  editedValue      String?
  effectiveValue   String?
  hasOverride      Boolean  @default(false)
  isMissing        Boolean  @default(false)
  isEdited         Boolean  @default(false)
  savedAt          DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  application  Application          @relation(fields: [applicationId], references: [id])
  secondaryRun SecondaryAnalysisRun @relation(fields: [secondaryRunId], references: [id])

  @@unique([secondaryRunId, no])
  @@index([applicationId, secondaryRunId])
}

model SupplementalFieldSubmission {
  id            String   @id @default(cuid())
  applicationId String
  analysisJobId String?
  fieldValues   Json
  submittedAt   DateTime @default(now())

  application Application @relation(fields: [applicationId], references: [id])
  analysisJob ResumeAnalysisJob? @relation(fields: [analysisJobId], references: [id])

  @@index([applicationId])
  @@index([analysisJobId])
}

model ApplicationMaterial {
  id            String           @id @default(cuid())
  applicationId String
  category      MaterialCategory
  fileName      String
  objectKey     String
  fileType      String
  fileSize      Int
  uploadedAt    DateTime         @default(now())
  isDeleted     Boolean          @default(false)
  deletedAt     DateTime?

  application Application @relation(fields: [applicationId], references: [id])

  @@index([applicationId, category])
  @@index([applicationId, isDeleted, category])
}

model ApplicationEventLog {
  id            String      @id @default(cuid())
  applicationId String
  eventType     String
  eventTime     DateTime    @default(now())
  pageName      String?
  stepName      String?
  actionName    String?
  eventStatus   EventStatus?
  errorCode     String?
  errorMessage  String?     @db.Text
  durationMs    Int?
  sessionId     String?
  requestId     String?
  ipAddress     String?
  ipHash        String?
  userAgent     String?
  referer       String?
  eventPayload  Json?
  createdAt     DateTime    @default(now())

  application Application @relation(fields: [applicationId], references: [id])

  @@index([applicationId, eventTime])
  @@index([eventType, eventTime])
  @@index([pageName, eventTime])
  @@index([stepName, eventTime])
  @@index([actionName, eventTime])
  @@index([eventStatus, eventTime])
  @@index([sessionId, eventTime])
  @@index([requestId])
  @@index([ipAddress, eventTime])
}

model InviteAccessLog {
  id            String                    @id @default(cuid())
  occurredAt    DateTime                  @default(now())
  invitationId  String?
  applicationId String?
  tokenStatus   AccessTokenStatusSnapshot @default(UNKNOWN)
  accessResult  AccessResult
  ipAddress     String?
  ipHash        String?
  userAgent     String?
  referer       String?
  landingPath   String?
  sessionId     String
  requestId     String
  utmSource     String?
  utmMedium     String?
  utmCampaign   String?
  createdAt     DateTime                  @default(now())

  invitation    ExpertInvitation?         @relation(fields: [invitationId], references: [id])
  application   Application?              @relation(fields: [applicationId], references: [id])

  @@index([occurredAt])
  @@index([invitationId, occurredAt])
  @@index([applicationId, occurredAt])
  @@index([accessResult, occurredAt])
  @@index([tokenStatus, occurredAt])
  @@index([sessionId, occurredAt])
  @@index([requestId])
  @@index([ipAddress, occurredAt])
  @@index([utmSource, utmMedium, utmCampaign])
}

model FileUploadAttempt {
  id                String             @id @default(cuid())
  applicationId     String
  uploadId          String?            @unique
  kind              UploadKind
  category          MaterialCategory?
  fileName          String
  fileExt           String?
  fileSize          Int?
  intentCreatedAt   DateTime?
  uploadStartedAt   DateTime?
  uploadConfirmedAt DateTime?
  uploadFailedAt    DateTime?
  failureCode       String?
  failureStage      UploadFailureStage?
  durationMs        Int?
  objectKey         String?
  sessionId         String?
  requestId         String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  application       Application        @relation(fields: [applicationId], references: [id])

  @@index([applicationId, kind, createdAt])
  @@index([applicationId, category, createdAt])
  @@index([kind, createdAt])
  @@index([failureStage, createdAt])
  @@index([sessionId, createdAt])
  @@index([requestId])
}
