generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum TokenStatus {
  ACTIVE
  EXPIRED
  DISABLED
}

enum ApplicationStatus {
  INIT
  INTRO_VIEWED
  CV_UPLOADED
  CV_EXTRACTING
  CV_EXTRACTION_REVIEW
  CV_ANALYZING
  INFO_REQUIRED
  REANALYZING
  INELIGIBLE
  ELIGIBLE
  SECONDARY_ANALYZING
  SECONDARY_REVIEW
  SECONDARY_FAILED
  MATERIALS_IN_PROGRESS
  SUBMITTED
  CLOSED
}

enum EligibilityResult {
  UNKNOWN
  INSUFFICIENT_INFO
  ELIGIBLE
  INELIGIBLE
}

enum AnalysisJobStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
}

enum AnalysisJobType {
  INITIAL
  REANALYSIS
}

enum ResumeExtractionReviewStatus {
  PROCESSING
  READY
  CONFIRMED
  FAILED
}

enum MaterialCategory {
  IDENTITY
  EMPLOYMENT
  EDUCATION
  HONOR
  PATENT
  PROJECT
  PAPER
  BOOK
  CONFERENCE
  PRODUCT
}

enum SupplementCategory {
  IDENTITY
  EDUCATION
  EMPLOYMENT
  PROJECT
  PATENT
  HONOR
}

enum MaterialReviewRunStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
}

enum MaterialReviewTriggerType {
  INITIAL_SUBMISSION
  SUPPLEMENT_UPLOAD
  MANUAL_RETRY
}

enum MaterialCategoryReviewStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
}

enum SupplementRequestStatus {
  PENDING
  UPLOADED_WAITING_REVIEW
  REVIEWING
  SATISFIED
  HISTORY_ONLY
}

enum SupplementUploadBatchStatus {
  DRAFT
  CONFIRMED
  REVIEWING
  COMPLETED
  CANCELLED
}

enum AccessResult {
  VALID
  INVALID
  EXPIRED
  DISABLED
  SESSION_RESTORE
}

enum AccessTokenStatusSnapshot {
  UNKNOWN
  ACTIVE
  EXPIRED
  DISABLED
}

enum EventStatus {
  SUCCESS
  FAIL
}

enum UploadKind {
  RESUME
  MATERIAL
}

enum UploadFailureStage {
  INTENT
  PUT
  CONFIRM
}

enum ApplicationFeedbackStatus {
  DRAFT
  SUBMITTED
}

model ExpertInvitation {
  id          String      @id @default(cuid())
  expertId    String
  email       String?
  tokenHash   String      @unique
  tokenStatus TokenStatus @default(ACTIVE)
  expiredAt   DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  applications Application[]
  accessLogs   InviteAccessLog[]

  @@index([expertId])
}

model Application {
  id                          String             @id @default(cuid())
  expertId                    String
  invitationId                String             @unique
  applicationStatus           ApplicationStatus  @default(INIT)
  currentStep                 String?
  eligibilityResult           EligibilityResult  @default(UNKNOWN)
  latestAnalysisJobId         String?
  firstAccessedAt             DateTime?
  lastAccessedAt              DateTime?
  introConfirmedAt            DateTime?
  resumeUploadStartedAt       DateTime?
  resumeUploadedAt            DateTime?
  analysisStartedAt           DateTime?
  analysisCompletedAt         DateTime?
  materialsEnteredAt          DateTime?
  submittedAt                 DateTime?
  screeningPassportFullName   String?
  screeningContactEmail       String?
  screeningWorkEmail          String?
  screeningPhoneNumber        String?
  productInnovationDescription String?          @db.Text
  createdAt                   DateTime           @default(now())
  updatedAt                   DateTime           @updatedAt

  invitation                  ExpertInvitation              @relation(fields: [invitationId], references: [id])
  resumeFiles                 ResumeFile[]
  analysisJobs                ResumeAnalysisJob[]
  analysisResults             ResumeAnalysisResult[]
  extractionReviews           ResumeExtractionReview[]
  secondaryAnalysisRuns       SecondaryAnalysisRun[]
  secondaryAnalysisFieldValues SecondaryAnalysisFieldValue[]
  supplementalFields          SupplementalFieldSubmission[]
  materials                   ApplicationMaterial[]
  materialReviewRuns          MaterialReviewRun[]
  materialCategoryReviews     MaterialCategoryReview[]
  supplementRequests          SupplementRequest[]
  supplementUploadBatches     SupplementUploadBatch[]
  supplementFiles             SupplementFile[]
  feedback                    ApplicationFeedback?
  events                      ApplicationEventLog[]
  accessLogs                  InviteAccessLog[]
  fileUploadAttempts          FileUploadAttempt[]

  @@index([expertId])
  @@index([applicationStatus])
  @@index([firstAccessedAt])
  @@index([lastAccessedAt])
  @@index([introConfirmedAt])
  @@index([resumeUploadedAt])
  @@index([analysisCompletedAt])
  @@index([materialsEnteredAt])
  @@index([submittedAt])
}

model ResumeFile {
  id            String      @id @default(cuid())
  applicationId String
  fileName      String
  objectKey     String
  fileType      String
  fileSize      Int
  versionNo     Int         @default(1)
  uploadedAt    DateTime    @default(now())

  application Application @relation(fields: [applicationId], references: [id])
  analysisJobs ResumeAnalysisJob[]

  @@index([applicationId])
  @@unique([applicationId, versionNo])
}

model ResumeAnalysisJob {
  id            String            @id @default(cuid())
  applicationId String
  resumeFileId  String?
  externalJobId String?           @unique
  jobType       AnalysisJobType
  jobStatus     AnalysisJobStatus @default(QUEUED)
  stageText     String?
  errorMessage  String?
  startedAt     DateTime          @default(now())
  finishedAt    DateTime?

  application                  Application                   @relation(fields: [applicationId], references: [id])
  resumeFile                   ResumeFile?                   @relation(fields: [resumeFileId], references: [id])
  analysisResult               ResumeAnalysisResult?
  extractionReview             ResumeExtractionReview?
  secondaryAnalysisRuns        SecondaryAnalysisRun[]
  supplementalFieldSubmissions SupplementalFieldSubmission[]

  @@index([applicationId])
  @@index([resumeFileId])
}

model ResumeAnalysisResult {
  id                String            @id @default(cuid())
  applicationId     String
  analysisJobId     String            @unique
  analysisRound     Int               @default(1)
  eligibilityResult EligibilityResult @default(UNKNOWN)
  reasonText        String?
  displaySummary    String?
  extractedFields   Json?
  missingFields     Json?
  createdAt         DateTime          @default(now())

  application Application @relation(fields: [applicationId], references: [id])
  analysisJob ResumeAnalysisJob @relation(fields: [analysisJobId], references: [id])

  @@index([applicationId])
}

model ResumeExtractionReview {
  id                    String                       @id @default(cuid())
  applicationId         String
  analysisJobId         String                       @unique
  externalJobId         String?
  status                ResumeExtractionReviewStatus @default(PROCESSING)
  extractedFields       Json?
  rawExtractionResponse String?                      @db.Text
  errorMessage          String?
  confirmedAt           DateTime?
  createdAt             DateTime                     @default(now())
  updatedAt             DateTime                     @updatedAt

  application Application       @relation(fields: [applicationId], references: [id])
  analysisJob ResumeAnalysisJob @relation(fields: [analysisJobId], references: [id])

  @@index([applicationId])
  @@index([status])
}

model SecondaryAnalysisRun {
  id             String   @id @default(cuid())
  applicationId  String
  analysisJobId  String?
  externalRunId  String
  status         String
  errorMessage   String?
  runSummary     Json?
  rawResults     Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  application Application @relation(fields: [applicationId], references: [id])
  analysisJob ResumeAnalysisJob? @relation(fields: [analysisJobId], references: [id])
  fieldValues SecondaryAnalysisFieldValue[]

  @@unique([applicationId, externalRunId])
  @@index([applicationId])
  @@index([analysisJobId])
}

model SecondaryAnalysisFieldValue {
  id               String   @id @default(cuid())
  applicationId    String
  secondaryRunId   String
  no               Int
  columnName       String?
  label            String
  sourceValue      String?
  editedValue      String?
  effectiveValue   String?
  hasOverride      Boolean  @default(false)
  isMissing        Boolean  @default(false)
  isEdited         Boolean  @default(false)
  savedAt          DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  application  Application          @relation(fields: [applicationId], references: [id])
  secondaryRun SecondaryAnalysisRun @relation(fields: [secondaryRunId], references: [id])

  @@unique([secondaryRunId, no])
  @@index([applicationId, secondaryRunId])
}

model SupplementalFieldSubmission {
  id            String   @id @default(cuid())
  applicationId String
  analysisJobId String?
  fieldValues   Json
  submittedAt   DateTime @default(now())

  application Application @relation(fields: [applicationId], references: [id])
  analysisJob ResumeAnalysisJob? @relation(fields: [analysisJobId], references: [id])

  @@index([applicationId])
  @@index([analysisJobId])
}

model ApplicationMaterial {
  id            String           @id @default(cuid())
  applicationId String
  category      MaterialCategory
  fileName      String
  objectKey     String
  fileType      String
  fileSize      Int
  uploadedAt    DateTime         @default(now())
  isDeleted     Boolean          @default(false)
  deletedAt     DateTime?

  application Application @relation(fields: [applicationId], references: [id])

  @@index([applicationId, category])
  @@index([applicationId, isDeleted, category])
}

model MaterialReviewRun {
  id                String                    @id @default(cuid())
  applicationId     String
  runNo             Int
  status            MaterialReviewRunStatus  @default(QUEUED)
  triggerType       MaterialReviewTriggerType
  triggeredCategory SupplementCategory?
  externalRunId     String?
  errorMessage      String?                   @db.Text
  startedAt         DateTime?
  finishedAt        DateTime?
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt

  application            Application              @relation(fields: [applicationId], references: [id])
  categoryReviews        MaterialCategoryReview[]
  supplementRequests     SupplementRequest[]
  supplementUploadBatches SupplementUploadBatch[]
  supplementFiles        SupplementFile[]

  @@unique([applicationId, runNo])
  @@index([applicationId])
  @@index([applicationId, status])
  @@index([externalRunId])
  @@index([createdAt])
}

model MaterialCategoryReview {
  id           String                       @id @default(cuid())
  reviewRunId  String
  applicationId String
  category     SupplementCategory
  roundNo      Int
  status       MaterialCategoryReviewStatus @default(QUEUED)
  aiMessage    String?                      @db.Text
  resultPayload Json?
  isLatest     Boolean                      @default(true)
  startedAt    DateTime?
  finishedAt   DateTime?
  createdAt    DateTime                     @default(now())
  updatedAt    DateTime                     @updatedAt

  reviewRun          MaterialReviewRun   @relation(fields: [reviewRunId], references: [id])
  application        Application         @relation(fields: [applicationId], references: [id])
  supplementRequests SupplementRequest[]

  @@unique([reviewRunId, category])
  @@unique([applicationId, category, roundNo])
  @@index([applicationId, category])
  @@index([applicationId, category, isLatest])
  @@index([reviewRunId])
  @@index([status, updatedAt])
}

model SupplementRequest {
  id               String                  @id @default(cuid())
  applicationId    String
  category         SupplementCategory
  reviewRunId      String
  categoryReviewId String
  title            String
  reason           String?                 @db.Text
  suggestedMaterials Json?
  aiMessage        String?                 @db.Text
  status           SupplementRequestStatus @default(PENDING)
  isLatest         Boolean                 @default(true)
  isSatisfied      Boolean                 @default(false)
  satisfiedAt      DateTime?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  application    Application            @relation(fields: [applicationId], references: [id])
  reviewRun      MaterialReviewRun      @relation(fields: [reviewRunId], references: [id])
  categoryReview MaterialCategoryReview @relation(fields: [categoryReviewId], references: [id])
  files          SupplementFile[]

  @@index([applicationId, category, isLatest])
  @@index([applicationId, status])
  @@index([applicationId, isSatisfied])
  @@index([reviewRunId])
  @@index([categoryReviewId])
}

model SupplementUploadBatch {
  id            String                      @id @default(cuid())
  applicationId String
  category      SupplementCategory
  status        SupplementUploadBatchStatus @default(DRAFT)
  fileCount     Int                         @default(0)
  reviewRunId   String?
  confirmedAt   DateTime?
  createdAt     DateTime                    @default(now())
  updatedAt     DateTime                    @updatedAt

  application Application       @relation(fields: [applicationId], references: [id])
  reviewRun   MaterialReviewRun? @relation(fields: [reviewRunId], references: [id])
  files       SupplementFile[]

  @@index([applicationId, category])
  @@index([applicationId, status])
  @@index([reviewRunId])
  @@index([createdAt])
}

model SupplementFile {
  id                  String              @id @default(cuid())
  applicationId       String
  category            SupplementCategory
  supplementRequestId String?
  uploadBatchId       String
  reviewRunId         String?
  fileName            String
  objectKey           String
  fileType            String
  fileSize            Int
  isDeleted           Boolean             @default(false)
  deletedAt           DateTime?
  uploadedAt          DateTime            @default(now())
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  application       Application        @relation(fields: [applicationId], references: [id])
  supplementRequest SupplementRequest? @relation(fields: [supplementRequestId], references: [id])
  uploadBatch       SupplementUploadBatch @relation(fields: [uploadBatchId], references: [id])
  reviewRun         MaterialReviewRun? @relation(fields: [reviewRunId], references: [id])

  @@index([applicationId, category])
  @@index([applicationId, uploadBatchId])
  @@index([reviewRunId])
  @@index([supplementRequestId])
}

model ApplicationFeedback {
  id            String                    @id @default(cuid())
  applicationId String                    @unique
  status        ApplicationFeedbackStatus @default(DRAFT)
  rating        Int?
  comment       String?                   @db.Text
  contextData   Json?
  draftSavedAt  DateTime?
  submittedAt   DateTime?
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt

  application Application @relation(fields: [applicationId], references: [id])

  @@index([status, updatedAt])
  @@index([submittedAt])
}

model ApplicationEventLog {
  id            String      @id @default(cuid())
  applicationId String
  eventType     String
  eventTime     DateTime    @default(now())
  pageName      String?
  stepName      String?
  actionName    String?
  eventStatus   EventStatus?
  errorCode     String?
  errorMessage  String?     @db.Text
  durationMs    Int?
  sessionId     String?
  requestId     String?
  ipAddress     String?
  ipHash        String?
  userAgent     String?
  referer       String?
  eventPayload  Json?
  createdAt     DateTime    @default(now())

  application Application @relation(fields: [applicationId], references: [id])

  @@index([applicationId, eventTime])
  @@index([eventType, eventTime])
  @@index([pageName, eventTime])
  @@index([stepName, eventTime])
  @@index([actionName, eventTime])
  @@index([eventStatus, eventTime])
  @@index([sessionId, eventTime])
  @@index([requestId])
  @@index([ipAddress, eventTime])
}

model InviteAccessLog {
  id            String                    @id @default(cuid())
  occurredAt    DateTime                  @default(now())
  invitationId  String?
  applicationId String?
  tokenStatus   AccessTokenStatusSnapshot @default(UNKNOWN)
  accessResult  AccessResult
  ipAddress     String?
  ipHash        String?
  userAgent     String?
  referer       String?
  landingPath   String?
  sessionId     String
  requestId     String
  utmSource     String?
  utmMedium     String?
  utmCampaign   String?
  createdAt     DateTime                  @default(now())

  invitation    ExpertInvitation?         @relation(fields: [invitationId], references: [id])
  application   Application?              @relation(fields: [applicationId], references: [id])

  @@index([occurredAt])
  @@index([invitationId, occurredAt])
  @@index([applicationId, occurredAt])
  @@index([accessResult, occurredAt])
  @@index([tokenStatus, occurredAt])
  @@index([sessionId, occurredAt])
  @@index([requestId])
  @@index([ipAddress, occurredAt])
  @@index([utmSource, utmMedium, utmCampaign])
}

model FileUploadAttempt {
  id                String             @id @default(cuid())
  applicationId     String
  uploadId          String?            @unique
  kind              UploadKind
  category          MaterialCategory?
  fileName          String
  fileExt           String?
  fileSize          Int?
  intentCreatedAt   DateTime?
  uploadStartedAt   DateTime?
  uploadConfirmedAt DateTime?
  uploadFailedAt    DateTime?
  failureCode       String?
  failureStage      UploadFailureStage?
  durationMs        Int?
  objectKey         String?
  sessionId         String?
  requestId         String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  application       Application        @relation(fields: [applicationId], references: [id])

  @@index([applicationId, kind, createdAt])
  @@index([applicationId, category, createdAt])
  @@index([kind, createdAt])
  @@index([failureStage, createdAt])
  @@index([sessionId, createdAt])
  @@index([requestId])
}
